<Project Sdk="Microsoft.NET.Sdk">
  <ItemGroup>
    <!-- Framework modules -->
    <ProjectReference Include="$(NacFrameworkSrc)/Nac.Core/Nac.Core.csproj" />
    <ProjectReference Include="$(NacFrameworkSrc)/Nac.Cqrs/Nac.Cqrs.csproj" />
    <ProjectReference Include="$(NacFrameworkSrc)/Nac.Persistence/Nac.Persistence.csproj" />
    <ProjectReference Include="$(NacFrameworkSrc)/Nac.EventBus/Nac.EventBus.csproj" />
    <!-- NOTE: Nac.Identity referenced for ICurrentUser (defined in Nac.Core.Abstractions.Identity)
         and for IPermissionDefinitionProvider (defined in Nac.Core.Abstractions.Permissions).
         Both interfaces live in Nac.Core, so no direct Nac.Identity reference is needed.
         Nac.WebApi referenced for ControllerBase + AuthorizeAttribute via FrameworkReference below. -->
    <ProjectReference Include="$(NacFrameworkSrc)/Nac.MultiTenancy/Nac.MultiTenancy.csproj" />
    <!-- Module public contracts -->
    <ProjectReference Include="../Orders.Contracts/Orders.Contracts.csproj" />
    <!-- Shared kernel: ResultExtensions.ToActionResult() -->
    <ProjectReference Include="../../../BuildingBlocks/ReferenceApp.SharedKernel/ReferenceApp.SharedKernel.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- ASP.NET Core for ControllerBase, [Authorize], [ApiController] -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <!-- EF Core Postgres provider for OrdersDbContext -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <!-- FluentValidation for CreateOrderValidator -->
    <PackageReference Include="FluentValidation" />
    <!-- EF Core Design for migrations (PrivateAssets=all — not deployed) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" PrivateAssets="all" />
  </ItemGroup>
</Project>
